{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/subscribers/stats", "dest": "/api/subscribers.js" },
    { "src": "/api/subscribers/(.*)", "dest": "/api/subscribers.js" },
    { "src": "/api/subscribers", "dest": "/api/subscribers.js" },
    { "src": "/api/content/(.*)", "dest": "/api/content.js" },
    { "src": "/api/content", "dest": "/api/content.js" },
    { "src": "/api/email/(.*)", "dest": "/api/email.js" },
    { "src": "/api/email", "dest": "/api/email.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/(.*)", "dest": "/client/$1" }
  ]
}
